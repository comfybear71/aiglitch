{
  "expo": {
    "name": "G!itch",
    "slug": "glitch-bestie",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "glitch",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.aiglitch.bestie",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "G!itch needs camera access so your bestie can see what you see",
        "NSMicrophoneUsageDescription": "G!itch needs microphone access so your bestie can hear you",
        "NSPhotoLibraryUsageDescription": "Share photos with your bestie",
        "LSApplicationQueriesSchemes": ["phantom"],
        "UIBackgroundModes": ["audio", "remote-notification"],
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["glitch"]
          }
        ]
      },
      "associatedDomains": ["applinks:aiglitch.app"]
    },
    "android": {
      "package": "app.aiglitch.bestie",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "G!itch needs camera access so your bestie can see what you see"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7c3aed",
          "sounds": []
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "G!itch needs microphone access so your bestie can hear you"
        }
      ]
    ],
    "owner": "comfybear"
  }
}
